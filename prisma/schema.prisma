// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String   
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expenses  Expense[]
  goals     SavingGoal[]
}

model Expense {
  id          Int         @id @default(autoincrement())
  title       String   
  amount      Decimal     @db.Decimal(12, 2)
  currency    String      @default("MMK")
  date        DateTime    @default(now())   
  userId      Int
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalId      Int?
  goal        SavingGoal? @relation(fields: [goalId], references: [id], onDelete: SetNull)
  @@index([userId])
  @@index([goalId])
}

model SavingGoal {
  id           Int                 @id @default(autoincrement())
  title        String              // e.g., "New Phone", "Emergency Fund"
  targetAmount Decimal             @db.Decimal(12, 2)
  currency     String              @default("MMK")
  status       String              @default("ACTIVE") // ACTIVE, COMPLETED, PAUSED
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  userId       Int
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions SavingTransaction[]
  expenses     Expense[]
  @@index([userId])
}

model SavingTransaction {
  id           Int        @id @default(autoincrement())
  amount       Decimal    @db.Decimal(12, 2) // Positive for savings, negative for withdrawals
  date         DateTime   @default(now())
  note         String?    // e.g., "Bonus cash allocation"
  goalId       Int
  goal         SavingGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  @@index([goalId])
}